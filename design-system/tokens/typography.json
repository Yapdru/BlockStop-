{
  "fontFamily": {
    "sans": [
      "Geist",
      "-apple-system",
      "BlinkMacSystemFont",
      "Segoe UI",
      "sans-serif"
    ],
    "mono": [
      "JetBrains Mono",
      "Menlo",
      "Courier New",
      "monospace"
    ]
  },
  "fontSize": {
    "xs": {
      "size": "12px",
      "lineHeight": "16px"
    },
    "sm": {
      "size": "14px",
      "lineHeight": "20px"
    },
    "base": {
      "size": "16px",
      "lineHeight": "24px"
    },
    "lg": {
      "size": "18px",
      "lineHeight": "28px"
    },
    "xl": {
      "size": "20px",
      "lineHeight": "28px"
    },
    "2xl": {
      "size": "24px",
      "lineHeight": "32px"
    },
    "3xl": {
      "size": "30px",
      "lineHeight": "36px"
    },
    "4xl": {
      "size": "36px",
      "lineHeight": "44px"
    }
  },
  "fontWeight": {
    "light": 300,
    "normal": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700,
    "extrabold": 800
  },
  "letterSpacing": {
    "tight": "-0.02em",
    "normal": "0em",
    "wide": "0.025em"
  }
}
