{
  "shadow": {
    "sm": {
      "box": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
    },
    "md": {
      "box": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
    },
    "lg": {
      "box": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
    },
    "xl": {
      "box": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
    },
    "2xl": {
      "box": "0 25px 50px -12px rgba(0, 0, 0, 0.25)"
    },
    "inner": {
      "box": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)"
    },
    "none": {
      "box": "0 0 #0000"
    }
  },
  "elevation": {
    "0": "none",
    "1": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "2": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
    "3": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
    "4": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
    "5": "0 25px 50px -12px rgba(0, 0, 0, 0.25)"
  }
}
