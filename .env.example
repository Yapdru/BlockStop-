# BlockStop Environment Configuration
# Copy this file to .env.local and fill in your values

# Next.js / NextAuth
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-random-secret-with-openssl-rand-base64-32

# Database
DATABASE_URL=postgresql://blockstop:blockstop@localhost:5432/blockstop_db

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# PayTM Payment Gateway
PAYTM_MERCHANT_ID=your-merchant-id
PAYTM_MERCHANT_KEY=your-merchant-key
PAYTM_CALLBACK_URL=https://yourdomain.com/api/billing/paytm/callback

# Optional: Redis Caching
REDIS_URL=redis://localhost:6379

# Optional: Stripe (if adding in future)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Optional: Sentry Error Tracking
SENTRY_DSN=https://key@sentry.io/project

# Feature Flags
ENABLE_FILE_UPLOAD=true
ENABLE_EMAIL_ANALYSIS=true
ENABLE_OAUTH=true
ENABLE_PAYMENTS=true

# Max File Upload Size (bytes)
MAX_FILE_SIZE=52428800

# Debug Mode
DEBUG=false
