{
  "manifest_version": 3,
  "name": "BlockStop - Advanced Threat Scanner",
  "version": "1.0.0",
  "description": "Universal threat scanner for emails, links, and files",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://inbox.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/worker.ts"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "BlockStop - Scan for threats"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/content/email-injector.ts"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/link-checker.ts"]
    }
  ]
}
