# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database Configuration
DATABASE_URL=postgresql://blockstop:blockstop@localhost:5432/blockstop_db

# Phase 2: Stripe Configuration (for subscription billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Phase 2: VPN API Keys
VPN_EXPRESSVPN_API_KEY=your-api-key
VPN_NORDVPN_API_KEY=your-api-key
VPN_SURFSHARK_API_KEY=your-api-key

# Phase 2: Antivirus/VirusTotal API
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# Feature Flags
ENABLE_FILE_UPLOAD=true
MAX_FILE_SIZE=52428800
DEBUG=false
